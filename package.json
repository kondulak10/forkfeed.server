{
  "name": "forkfeed-server",
  "version": "1.0.0",
  "description": "Lightweight edge-deployed content backend for the forkfeed protocol",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "node scripts/manifest-to-fork.mjs && tsc --noEmit && wrangler deploy",
    "publish": "npm run deploy && node scripts/publish.mjs",
    "register": "node scripts/publish.mjs",
    "typecheck": "tsc --noEmit",
    "convert": "node scripts/manifest-to-fork.mjs"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "typescript": "^5.9.0",
    "wrangler": "^4.9.0"
  }
}
